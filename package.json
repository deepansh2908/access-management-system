{
  "name": "multitenant-access-control",
  "version": "1.0.0",
  "description": "Reference implementation: access control across microservices in a multi-tenant SaaS",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "auth": "tsx src/auth-service/server.ts",
    "pdp": "tsx src/pdp/server.ts",
    "gateway": "tsx src/gateway/server.ts",
    "expense": "tsx src/services/expense/server.ts",
    "reporting": "tsx src/services/reporting/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx scripts/demo.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.9"
  }
}
